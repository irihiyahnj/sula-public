{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sula Project Manifest",
  "type": "object",
  "required": [
    "project",
    "repository",
    "rules",
    "stack",
    "paths",
    "commands",
    "deploy",
    "auth"
  ],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "slug", "description", "profile", "default_agent"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "slug": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "profile": {"type": "string", "minLength": 1},
        "default_agent": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "repository": {
      "type": "object",
      "required": ["primary_branch", "working_branch_prefix", "deployment_branch"],
      "properties": {
        "primary_branch": {"type": "string"},
        "working_branch_prefix": {"type": "string"},
        "deployment_branch": {"type": "string"}
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "object",
      "required": ["highest_rule", "custom_backend_allowed", "react_router_allowed"],
      "properties": {
        "highest_rule": {"type": "string"},
        "custom_backend_allowed": {"type": "boolean"},
        "react_router_allowed": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "stack": {
      "type": "object",
      "required": ["frontend", "backend"],
      "properties": {
        "frontend": {"type": "string"},
        "backend": {"type": "string"}
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "required": ["api_layer", "state_layer", "app_shell", "status_file", "change_records_file"],
      "properties": {
        "api_layer": {"type": "string"},
        "state_layer": {"type": "string"},
        "app_shell": {"type": "string"},
        "status_file": {"type": "string"},
        "change_records_file": {"type": "string"}
      },
      "additionalProperties": false
    },
    "commands": {
      "type": "object",
      "required": ["install", "dev", "build", "typecheck"],
      "properties": {
        "install": {"type": "string"},
        "dev": {"type": "string"},
        "build": {"type": "string"},
        "typecheck": {"type": "string"}
      },
      "additionalProperties": false
    },
    "deploy": {
      "type": "object",
      "required": ["base_path", "production_url", "workflow"],
      "properties": {
        "base_path": {"type": "string"},
        "production_url": {"type": "string"},
        "workflow": {"type": "string"}
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "required": ["session_expiry_codes", "permission_denied_codes"],
      "properties": {
        "session_expiry_codes": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "permission_denied_codes": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "memory": {
      "type": "object",
      "required": [
        "change_record_directory",
        "release_record_directory",
        "incident_record_directory",
        "digest_file",
        "status_max_age_days"
      ],
      "properties": {
        "change_record_directory": {"type": "string", "minLength": 1},
        "release_record_directory": {"type": "string", "minLength": 1},
        "incident_record_directory": {"type": "string", "minLength": 1},
        "digest_file": {"type": "string", "minLength": 1},
        "status_max_age_days": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "required": ["pack", "stage", "artifacts_root"],
      "properties": {
        "pack": {"type": "string", "minLength": 1},
        "stage": {"type": "string", "minLength": 1},
        "artifacts_root": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "storage": {
      "type": "object",
      "required": ["provider", "sync_mode", "workspace_root", "provider_root_url", "provider_root_id"],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "sync_mode": {"type": "string", "minLength": 1},
        "workspace_root": {"type": "string", "minLength": 1},
        "provider_root_url": {"type": "string", "minLength": 1},
        "provider_root_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "portfolio": {
      "type": "object",
      "required": ["portfolio_id", "workspace", "owner"],
      "properties": {
        "portfolio_id": {"type": "string", "minLength": 1},
        "workspace": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "language": {
      "type": "object",
      "required": ["content_locale", "interaction_locale", "preserve_user_input_language"],
      "properties": {
        "content_locale": {"type": "string", "minLength": 1},
        "interaction_locale": {"type": "string", "minLength": 1},
        "preserve_user_input_language": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "projection": {
      "type": "object",
      "required": ["mode", "enabled_packs"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["detached", "collaborative", "governed"]
        },
        "enabled_packs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "project-memory",
              "record-templates",
              "document-design",
              "ops-core",
              "profile-architecture",
              "profile-runbooks",
              "ai-tooling"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "document_design": {
      "type": "object",
      "required": [
        "principles_path",
        "source_first",
        "register_derived_artifacts",
        "preferred_source_format",
        "schedule_bundle",
        "proposal_bundle",
        "report_bundle",
        "process_bundle",
        "training_bundle"
      ],
      "properties": {
        "principles_path": {"type": "string", "minLength": 1},
        "source_first": {"type": "boolean"},
        "register_derived_artifacts": {"type": "boolean"},
        "preferred_source_format": {"type": "string", "minLength": 1},
        "schedule_bundle": {"type": "string", "minLength": 1},
        "proposal_bundle": {"type": "string", "minLength": 1},
        "report_bundle": {"type": "string", "minLength": 1},
        "process_bundle": {"type": "string", "minLength": 1},
        "training_bundle": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
