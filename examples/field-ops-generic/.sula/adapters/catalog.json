{
  "version": "0.13.0",
  "profile": "generic-project",
  "adapters": [
    {
      "id": "generic-project",
      "kind": "base",
      "required": true,
      "enabled": true,
      "git_required": false,
      "description": "Minimum removable project kernel.",
      "source_matchers": [
        "*"
      ]
    },
    {
      "id": "docs",
      "kind": "core",
      "required": true,
      "enabled": true,
      "git_required": false,
      "description": "Project documents and source anchors.",
      "source_matchers": [
        "README.md",
        "docs/**",
        "*.md"
      ]
    },
    {
      "id": "memory",
      "kind": "core",
      "required": true,
      "enabled": true,
      "git_required": false,
      "description": "State, change history, and recall views.",
      "source_matchers": [
        ".sula/**",
        "STATUS.md",
        "CHANGE-RECORDS.md",
        "docs/change-records/**",
        "docs/releases/**",
        "docs/incidents/**"
      ]
    },
    {
      "id": "repo",
      "kind": "core",
      "required": false,
      "enabled": true,
      "git_required": true,
      "description": "Git-aware repository metadata and workflows.",
      "source_matchers": [
        ".git",
        ".github/**",
        "*"
      ]
    },
    {
      "id": "local-fs",
      "kind": "core",
      "required": false,
      "enabled": true,
      "git_required": false,
      "description": "Local filesystem workspace adapter.",
      "source_matchers": [
        "*"
      ],
      "provider": "local-fs",
      "sync_mode": "local-only",
      "workspace_root": ".",
      "provider_root_url": "local-only",
      "provider_root_id": "n/a"
    }
  ]
}
